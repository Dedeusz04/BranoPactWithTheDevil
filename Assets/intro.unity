  m_FontData:
    m_Font: {fileID: 10102, guid: 0000000000000000e000000000000000, type: 0}
    m_FontSize: 12
    m_FontStyle: 0
    m_BestFit: 1
    m_MinSize: 0
    m_MaxSize: 64
    m_Alignment: 1
    m_AlignByGeometry: 1
    m_RichText: 0
    m_HorizontalOverflow: 0
    m_VerticalOverflow: 0
    m_LineSpacing: 1.04
  m_Text: "Serbski komandos - Brano, otrzymuje kolejn\u0105 do zrealizowania misj\u0119.
    Udaje si\u0119 do Nigerii, aby rozprawi\u0107 si\u0119 tam z najemnikami terroryzuj\u0105cymi
    lokaln\u0105 spo\u0142eczno\u015B\u0107. Wsparty Przez CIA oraz Izraelski wywiad,
    dobrze poinformowany i wyposa\u017Cony, rozpoczyna najci\u0119\u017Csz\u0105
    misj\u0119 w swoim \u017Cyciu. Jego plany zamierza pokrzy\u017Cowa\u0107 jednak
    jego odwieczny wr\xF3g - przyw\xF3dca najemnik\xF3w, rosyjski genera\u0142 Dominik
    R. Sochov. Jego aktualnym zadaniem jest przygotowanie broni na swoj\u0105 g\u0142\xF3wn\u0105
    misj\u0119."
